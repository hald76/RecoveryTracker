@inject IEntryService EntrySvc

<MudDialog>
    <DialogContent>
        <MudStack Spacing="6">
            <MudStack Row="true" Spacing="4">
                <MudDatePicker @bind-Date="_date" Label="Date" Variant="Variant.Outlined" />
                <MudTimePicker @bind-Time="_time" Label="Time" Variant="Variant.Outlined" />
            </MudStack>

            <div>
                <MudText Typo="Typo.subtitle1">😊 Pain level: @_entry.PainLevel / 10</MudText>
                <MudSlider @bind-Value="_entry.PainLevel" Min="0" Max="10" Step="1" Color="Color.Primary" />
            </div>

            <div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">🛠️ Activity</MudText>
                <MudSelect T="string" Value="@_selectedActivity" ValueChanged="OnActivityChanged" Variant="Variant.Outlined">
                    @foreach (var activity in WorkActivities.All)
                    {
                        <MudSelectItem Value="@activity">@WorkActivities.Emoji(activity) @activity</MudSelectItem>
                    }
                </MudSelect>

                @if (_selectedActivity == WorkActivities.Other)
                {
                    <MudTextField @bind-Value="_entry.ActivityName" Immediate="true" Label="Custom activity" Variant="Variant.Outlined" Class="mt-3" />
                }

                <MudText Typo="Typo.body2" Class="muted mt-3">@_entry.ActivityMinutes min</MudText>
                <MudSlider @bind-Value="_entry.ActivityMinutes" Min="1" Max="180" Step="1" Color="Color.Primary" />
            </div>

            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudSwitch @bind-Value="_entry.IceApplied" Color="Color.Info" Label="🧊 Ice applied" />
                <MudSwitch @bind-Value="_entry.MedicationTaken" Color="Color.Success" Label="💊 Medication taken" />
            </MudStack>

            <div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">🦵 Swelling</MudText>
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                    @foreach (var level in Enum.GetValues<SwellingLevel>())
                    {
                        <MudButton Variant="@(_entry.Swelling == level ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => _entry.Swelling = level)">@level</MudButton>
                    }
                </MudButtonGroup>
            </div>

            <MudTextField @bind-Value="_entry.Note" Immediate="true" Label="📝 Quick note" Variant="Variant.Outlined" Lines="3" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DailyEntry Entry { get; set; } = new();

    DailyEntry _entry = new();
    DateTime? _date;
    TimeSpan? _time;
    string _selectedActivity = "Computer desk work";

    protected override void OnInitialized()
    {
        _entry = new DailyEntry
        {
            Id = Entry.Id,
            Timestamp = Entry.Timestamp,
            PainLevel = Entry.PainLevel,
            ActivityName = Entry.ActivityName,
            ActivityMinutes = Entry.ActivityMinutes,
            IceApplied = Entry.IceApplied,
            MedicationTaken = Entry.MedicationTaken,
            Swelling = Entry.Swelling,
            Note = Entry.Note
        };
        _date = _entry.Timestamp.Date;
        _time = _entry.Timestamp.TimeOfDay;
        _selectedActivity = WorkActivities.Fixed.Contains(_entry.ActivityName) ? _entry.ActivityName : WorkActivities.Other;
    }

    void OnActivityChanged(string value)
    {
        _selectedActivity = value;
        if (value != WorkActivities.Other) _entry.ActivityName = value;
        else if (WorkActivities.Fixed.Contains(_entry.ActivityName)) _entry.ActivityName = "";
    }

    async Task SaveAsync()
    {
        var datePart = (_date ?? DateTime.Now).Date;
        var timePart = _time ?? DateTime.Now.TimeOfDay;
        _entry.Timestamp = datePart + timePart;
        var saved = await EntrySvc.UpsertAsync(_entry);
        MudDialog.Close(DialogResult.Ok(saved));
    }

    void Cancel() => MudDialog.Cancel();
}
