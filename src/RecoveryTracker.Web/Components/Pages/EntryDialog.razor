@inject IEntryService EntrySvc

<MudDialog>
    <DialogContent>
        <MudStack Spacing="6">
            <div>
                <MudDatePicker @bind-Date="_date" Label="Date" Variant="Variant.Outlined" />
            </div>

            <div>
                <MudText Typo="Typo.subtitle1">😊 Pain level: @_entry.PainLevel / 10</MudText>
                <MudSlider @bind-Value="_entry.PainLevel" Min="0" Max="10" Step="1" Color="Color.Primary" />
            </div>

            <div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">🛠️ Activities</MudText>
                <MudStack>
                    @foreach (var activity in WorkActivities.Fixed)
                    {
                        <MudCheckBox T="bool" Value="@_entry.Activities.Contains(activity)"
                                     ValueChanged="@(v => ToggleActivity(activity, v))"
                                     Label="@($"{WorkActivities.Emoji(activity)} {activity}")" Color="Color.Primary" />
                    }
                </MudStack>

                @{ var customTags = _entry.Activities.Except(WorkActivities.Fixed).ToList(); }
                @if (customTags.Count > 0)
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                        @foreach (var tag in customTags)
                        {
                            <MudChip T="string" Color="Color.Secondary" Size="Size.Small"
                                     OnClose="@(_ => RemoveTag(tag))">@tag</MudChip>
                        }
                    </MudStack>
                }

                <MudStack Row="true" Spacing="2" Class="mt-2" AlignItems="AlignItems.End">
                    <MudTextField @bind-Value="_newTag" Immediate="true" Label="Other (custom activity)" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Outlined" OnClick="AddTag">Add</MudButton>
                </MudStack>
            </div>

            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudSwitch @bind-Value="_entry.IceApplied" Color="Color.Info" Label="🧊 Ice applied" />
                <MudSwitch @bind-Value="_entry.MedicationTaken" Color="Color.Success" Label="💊 Medication taken" />
            </MudStack>

            <div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">🦵 Swelling</MudText>
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                    @foreach (var level in Enum.GetValues<SwellingLevel>())
                    {
                        <MudButton Variant="@(_entry.Swelling == level ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => _entry.Swelling = level)">@level</MudButton>
                    }
                </MudButtonGroup>
            </div>

            <MudTextField @bind-Value="_entry.Note" Immediate="true" Label="📝 Quick note" Variant="Variant.Outlined" Lines="3" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DailyEntry Entry { get; set; } = new();

    DailyEntry _entry = new();
    DateTime? _date;
    string _newTag = "";

    protected override void OnInitialized()
    {
        _entry = new DailyEntry
        {
            Id = Entry.Id,
            EntryDate = Entry.EntryDate,
            PainLevel = Entry.PainLevel,
            Activities = new List<string>(Entry.Activities),
            IceApplied = Entry.IceApplied,
            MedicationTaken = Entry.MedicationTaken,
            Swelling = Entry.Swelling,
            Note = Entry.Note
        };
        _date = _entry.EntryDate.ToDateTime(TimeOnly.MinValue);
    }

    void ToggleActivity(string activity, bool selected)
    {
        if (selected) { if (!_entry.Activities.Contains(activity)) _entry.Activities.Add(activity); }
        else { _entry.Activities.Remove(activity); }
    }

    void AddTag()
    {
        var tag = _newTag.Trim();
        if (!string.IsNullOrWhiteSpace(tag) && !_entry.Activities.Contains(tag))
            _entry.Activities.Add(tag);
        _newTag = "";
    }

    void RemoveTag(string tag) => _entry.Activities.Remove(tag);

    async Task SaveAsync()
    {
        _entry.EntryDate = DateOnly.FromDateTime(_date ?? DateTime.Now);
        var saved = await EntrySvc.UpsertAsync(_entry);
        MudDialog.Close(DialogResult.Ok(saved));
    }

    void Cancel() => MudDialog.Cancel();
}
