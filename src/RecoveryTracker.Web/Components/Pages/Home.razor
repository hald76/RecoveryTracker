@page "/"
@inject IEntryService EntrySvc
@inject IProfileService ProfileSvc
@inject ISnackbar Snackbar

<PageTitle>Today — Recovery Tracker</PageTitle>

@if (_entry is null)
{
    <MudText>Loading…</MudText>
}
else
{
    <MudStack Spacing="0" Class="mb-4">
        <MudText Typo="Typo.h4">Today</MudText>
        <MudText Typo="Typo.body2" Class="muted">
            @_today.ToString("dddd, MMMM d, yyyy")
            @if (_dayNumber is { } d)
            {
                <span> &nbsp;•&nbsp; Day @d post-op</span>
            }
        </MudText>
    </MudStack>

    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="6">
            <div>
                <MudText Typo="Typo.subtitle1">😊 Pain level: @_entry.PainLevel / 10</MudText>
                <MudSlider @bind-Value="_entry.PainLevel" Min="0" Max="10" Step="1" Color="Color.Primary" />
            </div>

            <div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">🛠️ Activities</MudText>
                @foreach (var activity in WorkActivities.Fixed)
                {
                    var current = _entry.Activities.FirstOrDefault(a => a.Name == activity);
                    <div class="mb-3">
                        <MudCheckBox T="bool" Value="@(current is not null)"
                                     ValueChanged="@(v => ToggleActivity(activity, v))"
                                     Label="@($"{WorkActivities.Emoji(activity)} {activity}")" Color="Color.Primary" />
                        @if (current is not null)
                        {
                            <MudText Typo="Typo.body2" Class="muted ml-8">@current.Minutes min</MudText>
                            <div class="ml-8">
                                <MudSlider T="int" Value="@current.Minutes" ValueChanged="@(v => current.Minutes = v)"
                                           Min="1" Max="180" Step="1" Color="Color.Primary" />
                            </div>
                        }
                    </div>
                }

                @{ var customTags = _entry.Activities.Where(a => !WorkActivities.Fixed.Contains(a.Name)).ToList(); }
                @foreach (var tag in customTags)
                {
                    <div class="mb-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudChip T="string" Color="Color.Secondary" Size="Size.Small"
                                     OnClose="@(_ => RemoveTag(tag.Name))">@tag.Name</MudChip>
                            <MudText Typo="Typo.body2" Class="muted">@tag.Minutes min</MudText>
                        </MudStack>
                        <MudSlider T="int" Value="@tag.Minutes" ValueChanged="@(v => tag.Minutes = v)"
                                   Min="1" Max="180" Step="1" Color="Color.Secondary" />
                    </div>
                }

                <MudStack Row="true" Spacing="2" Class="mt-2" AlignItems="AlignItems.End">
                    <MudTextField @bind-Value="_newTag" Immediate="true" Label="Other (custom activity)" Variant="Variant.Outlined" />
                    <MudButton Variant="Variant.Outlined" OnClick="AddTag">Add</MudButton>
                </MudStack>
            </div>

            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudSwitch @bind-Value="_entry.IceApplied" Color="Color.Info" Label="🧊 Ice applied" />
                <MudSwitch @bind-Value="_entry.MedicationTaken" Color="Color.Success" Label="💊 Medication taken" />
            </MudStack>

            <div>
                <MudText Typo="Typo.subtitle1" Class="mb-1">🦵 Swelling</MudText>
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                    @foreach (var level in Enum.GetValues<SwellingLevel>())
                    {
                        <MudButton Variant="@(_entry.Swelling == level ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => _entry.Swelling = level)">@level</MudButton>
                    }
                </MudButtonGroup>
            </div>

            <MudTextField @bind-Value="_entry.Note" Immediate="true" Label="📝 Quick note" Variant="Variant.Outlined" Lines="3" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Check" OnClick="SaveAsync">
                Save today's entry
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    DailyEntry? _entry;
    DateOnly _today;
    int? _dayNumber;
    string _newTag = "";

    protected override async Task OnInitializedAsync()
    {
        _today = DateOnly.FromDateTime(DateTime.Now);
        _entry = await EntrySvc.GetByDateAsync(_today) ?? new DailyEntry { EntryDate = _today };

        var profile = await ProfileSvc.GetAsync();
        if (profile.SurgeryDate is { } sd)
            _dayNumber = _today.DayNumber - sd.DayNumber;
    }

    void ToggleActivity(string activity, bool selected)
    {
        if (selected) { if (!_entry!.Activities.Any(a => a.Name == activity)) _entry.Activities.Add(new ActivityEntry { Name = activity, Minutes = 15 }); }
        else { _entry!.Activities.RemoveAll(a => a.Name == activity); }
    }

    void AddTag()
    {
        var tag = _newTag.Trim();
        if (!string.IsNullOrWhiteSpace(tag) && !_entry!.Activities.Any(a => a.Name == tag))
            _entry.Activities.Add(new ActivityEntry { Name = tag, Minutes = 15 });
        _newTag = "";
    }

    void RemoveTag(string name) => _entry!.Activities.RemoveAll(a => a.Name == name);

    async Task SaveAsync()
    {
        _entry = await EntrySvc.UpsertAsync(_entry!);
        Snackbar.Add("Saved today's entry", Severity.Success);
    }
}
